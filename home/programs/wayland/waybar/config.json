{
    "layer": "top",
    "position": "top",
    "height": 21,
    "modules-left": [
      "group/power",
      "custom/cap-left", 
      "group/windows", 
      "custom/cap-left#dark", 
      "custom/gap",
      "network",
      "bluetooth",
      "custom/cap-left",
      "battery"
    ],
    "modules-center": [""],
    "modules-right": ["custom/cap-right#dark", "clock#clock2", "custom/cap-right","clock" ],
    "battery": {
      "bat": "BAT0",
      "min-length": 5,
      "states": {
      "full": 95,
      "warning": 30,
      "critical": 15
      },
      "tooltip": false,
      "full-at": 90,
      "format-plugged": "{icon} {capacity}%",
      "format-charging": "{icon} {capacity}%",
      "format": "{icon} {capacity}%",
      "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },
    "group/windows": {
      "orientation": "horizontal",
      "drawer": {
        "transition-duration": 500,
        "transition-left-to-right": false,
        "click-to-reveal": true
      },
      "modules": [
        "hyprland/workspaces",
        "hyprland/window"
      ]
    },
    "group/power": {
      "orientation": "horizontal",
      "drawer": {
        "transition-duration": 500,
        "transition-left-to-right": false,
        "click-to-reveal": true
    
      },
      "modules": [
        "custom/logo",
        "custom/power",
        "custom/lock"
      ]
    },
    "custom/lock": {
        "format": "у°ЌЃ",
