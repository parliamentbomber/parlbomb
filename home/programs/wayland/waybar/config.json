        "on-click": "hyprlock"
    },
    "custom/power": {
        "format": "пЂ‘",
        "tooltip": false,
        "on-click": "systemctl shutdown"
    },
    "hyprland/workspaces": {
      "active-only": true,
      "format": "{id}"
    },
    "hyprland/window": {
      "format": "{title}"
    },
    
    "clock": {
      "format": "пЃі {:%Y-%m-%d}",
      "tooltip": false
    },
    "clock#clock2": {
      "format": "пЂ— {:%H:%M}",
      "tooltip": false
    },
    "network": {
      "format-wifi": "п‡«  {essid}",
      "format-ethernet": "пѓЁ {ipaddr}",
      "format-linked": "пѓЃ {ipaddr}",
      "format-disconnected": "пЃ± Disconnected",
      "format-disabled": "",
      "tooltip": false,
      "max-length": 21,
      "min-length": 6
    },
    "pulseaudio": {
      "tooltip": false,
